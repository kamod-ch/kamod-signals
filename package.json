{
  "name": "@kamod-ch/signals",
  "version": "0.1.0",
  "description": "Persisted Preact signals with localStorage, sessionStorage, IndexedDB, cookie, and memory drivers.",
  "type": "module",
  "license": "MIT",
  "author": "Klaus Zahiragic <watzak>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kamod-ch/kamod-signals.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "docs:dev": "pnpm --dir docs dev",
    "docs:check": "pnpm --dir docs check",
    "docs:build": "pnpm --dir docs build",
    "docs:preview": "pnpm --dir docs preview"
  },
  "peerDependencies": {
    "@preact/signals": "^2.0.0",
    "preact": "^10.0.0"
  },
  "devDependencies": {
    "@preact/signals": "^2.9.1",
    "@types/node": "^24.3.0",
    "jsdom": "^26.1.0",
    "preact": "^10.27.2",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vitest": "^4.0.3"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
